---
// src/components/ShortcutGrid.astro
const { columns } = Astro.props;
---

<div class="w-full bg-[#2c2c2c] rounded-md border border-neutral-700 overflow-hidden shadow-xl font-sans my-8 p-6 lg:p-8">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-8">
    {columns.map((col: any) => (
      <div class="flex flex-col gap-4">
        {col.map((item: any) => (
          <div class="flex items-center justify-between w-full">
            <span class={`text-sm tracking-wide ${item.highlighted ? 'text-[#559ef6]' : 'text-neutral-300'}`}>
              {item.label}
            </span>
            <div class="flex items-center gap-1.5">
              {item.keys.map((k: any) => (
                <kbd class={`inline-flex items-center justify-center min-w-[32px] h-8 px-2 text-sm font-sans rounded transition-colors ${k.filled ? 'bg-[#559ef6] text-neutral-900 font-medium border border-[#559ef6]' : 'border border-neutral-500 text-neutral-300 bg-transparent'}`}>
                  {k.key}
                </kbd>
              ))}
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</div>

