---
// src/components/Kbd.astro
interface Props {
  filled?: boolean;
}
const { filled = false } = Astro.props;

const baseStyles = "inline-flex items-center justify-center min-w-[32px] h-8 px-2 text-sm font-sans rounded transition-colors";
const outlineStyles = "border border-neutral-500 text-neutral-300 bg-transparent";
const filledStyles = "bg-[#559ef6] text-neutral-900 font-medium border border-[#559ef6]";
---

<kbd class:list={[baseStyles, filled ? filledStyles : outlineStyles]}>
  <slot />
</kbd>

