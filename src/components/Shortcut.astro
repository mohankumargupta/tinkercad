---
// src/components/Shortcut.astro
interface Props {
  label: string;
  highlighted?: boolean;
}
const { label, highlighted = false } = Astro.props;
---

<div class="contents">
  <span class:list={[
    "text-sm tracking-wide leading-tight items-baseline",
    highlighted ? "text-[#559ef6]" : "text-neutral-300"
  ]}>
    {label}
  </span>
  <div class="flex items-baseline gap-1.5">
    <slot />
  </div>
</div>